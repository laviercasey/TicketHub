# ============================================
# TicketHub Environment Configuration
# ============================================
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# These variables are used by:
#   1. Docker Compose — to create the MySQL container
#   2. PHP (th-config.php) — to connect to the database
# ============================================

# MySQL root password (used only by Docker to init the container)
MYSQL_ROOT_PASSWORD=change_me_root_password

# Database settings (shared by Docker and PHP)
MYSQL_DATABASE=tickethub
MYSQL_USER=tickethub
MYSQL_PASSWORD=change_me_strong_password

# TicketHub application settings
DB_HOST=db
DB_NAME=tickethub
DB_USER=tickethub
DB_PASS=change_me_strong_password

# Security — generate with: openssl rand -hex 32
SECRET_SALT=change_me_generate_random_32_hex

# Session secret — generate with: openssl rand -hex 32
SESSION_SECRET=change_me_generate_random_32_hex

# Admin email for system alerts
ADMIN_EMAIL=admin@yourdomain.com

# Application environment (local, staging, production)
APP_ENV=local

# Debug mode (1 = enabled, 0 = disabled)
APP_DEBUG=1

# Table prefix
DB_PREFIX=th_

# Application version
APP_VERSION=1.0

# Image tag (used by docker-compose for versioned deployments)
IMAGE_TAG=latest

# First admin (only used on fresh install when th_staff is empty)
# Generate hash: php -r "echo password_hash('YourPassword', PASSWORD_DEFAULT);"
ADMIN_USERNAME=admin
FIRST_ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=
